# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit real secrets — only the template)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# قاعدة البيانات (تحتوي بيانات حساسة — لا ترفعها)
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-shm
/prisma/*.db-wal

# ملفات تم رفعها من المستخدمين
/uploads
/public/uploads

# Capacitor builds
/android/app/build
/android/.gradle
/android/build
/android/local.properties
/ios/App/build
/ios/App/Pods
/ios/DerivedData

# IDE
.idea
.vscode
*.swp
*.swo

# OS
Thumbs.db

# Claude Code local session files
.claude/

# Scripts عينات/اختبار (لا ترفعها لأنها قد تحوي كلمات مرور)
check_users.mjs

# SSL certificates (mounted into nginx at runtime, never in repo)
/ssl
*.pem
*.key
*.crt

# Backups (mounted as Docker volume in production)
/backups
