# ══════════════════════════════════════════════════════════
# MawaridX — Environment Variables Template
# Copy to `.env` (or set in Hostinger Docker Manager UI) and
# fill in real values. NEVER commit a populated .env to Git.
# ══════════════════════════════════════════════════════════

# ──────────────── Database ────────────────
# SQLite path inside the container. Mounted from a Docker volume
# in compose, so the file persists across container restarts.
# Each tenant container gets its own volume → its own DB file.
DATABASE_URL="file:./prisma/hr.db"

# ──────────────── Authentication ────────────────
# Secret used to sign JWT session tokens. Generate a strong one:
#   openssl rand -base64 64
# Rotating this invalidates all existing sessions.
JWT_SECRET=

# Comma-separated list of super admin emails (system owners).
# These bypass tenant-level checks and trigger 2FA OTP on login.
SUPER_ADMIN_EMAILS=admin@mawaridx.com

# ──────────────── Backups ────────────────
# How often (in hours) to auto-backup the SQLite DB. Default 24.
# Last 14 backups are kept in /app/backups (mounted volume).
BACKUP_INTERVAL_HOURS=24

# ──────────────── Web Push Notifications ────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Public key is shipped to clients (NEXT_PUBLIC_) — safe to expose.
# Private key MUST stay server-side.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@mawaridx.com

# ──────────────── SMTP (set via the Settings UI, not here) ────────────────
# SMTP credentials are stored in the DB (Setting model) so each
# tenant can configure its own. These ENV vars are only needed if
# you want to seed defaults — typically leave them empty.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ══════════════════════════════════════════════════════════
# Tenant configuration (one set per tenant container)
# ══════════════════════════════════════════════════════════

# Tenant A
COMPANY_A_NAME="Company A"
COMPANY_A_URL="https://company-a.mawaridx.com"

# Tenant B
COMPANY_B_NAME="Company B"
COMPANY_B_URL="https://company-b.mawaridx.com"

# Tenant C
COMPANY_C_NAME="Company C"
COMPANY_C_URL="https://company-c.mawaridx.com"
