# ──────────── Dependencies & build artifacts ────────────
node_modules
.next
out
build
dist
*.tsbuildinfo
next-env.d.ts

# ──────────── Source control & IDE ────────────
.git
.github
.gitignore
.gitattributes
.vscode
.idea
*.swp
*.swo

# ──────────── Environment files (NEVER ship secrets in image) ────────────
.env
.env.*
!.env.example

# ──────────── Logs ────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ──────────── Database files (created at runtime, mounted as volume) ────────────
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal

# ──────────── User uploads (volume-mounted at runtime) ────────────
uploads
public/uploads

# ──────────── Backups (volume-mounted at runtime) ────────────
backups

# ──────────── Mobile builds (Capacitor) — not needed in server image ────────────
android
ios
build-app.sh
capacitor.config.ts

# ──────────── Documentation (not needed at runtime) ────────────
README.md
README-DEPLOY.md
AGENTS.md
CLAUDE.md
*.md

# ──────────── Test artifacts ────────────
coverage
.nyc_output

# ──────────── Claude Code session files ────────────
.claude

# ──────────── OS files ────────────
.DS_Store
Thumbs.db

# ──────────── Misc ────────────
.vercel
*.pem
check_users.mjs
new-tenant.sh

# ──────────── Docker files (don't copy into image) ────────────
Dockerfile
docker-compose*.yml
.dockerignore
